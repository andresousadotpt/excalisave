# Database
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/excalisave?schema=public"

# NextAuth
AUTH_SECRET="generate-with-openssl-rand-base64-32"
AUTH_URL="http://localhost:3000"

# App (APP_URL is used server-side for emails/redirects; APP_URL is build-time only)
APP_URL="http://localhost:3000"

# Registration (set to "false" to disable public registration)
REGISTRATION_ENABLED="true"

# Email (Resend)
RESEND_API_KEY="re_xxxxxxxxxxxx"
EMAIL_FROM="Excalisave <noreply@yourdomain.com>"

# Server-side encryption (AES-256-GCM for PII like emails and drawing names)
# Generate with: openssl rand -hex 32
ENCRYPTION_KEY="generate-with-openssl-rand-hex-32"

# Collaboration (leave COLLAB_URL empty to hide the Share button)
COLLAB_URL="ws://localhost:4000"
COLLAB_ALLOWED_ORIGINS="http://localhost:3000"

# Admin (default admin created on first run)
ADMIN_EMAIL="admin@example.com"
ADMIN_PASSWORD="change-me-on-first-login"
